{
  "name": "amas-seminary",
  "version": "0.1.0",
  "private": true,
  "description": "Rebuilt source workspace for AMAS Seminary after source deletion.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:remote": "VITE_APP_GATEWAY_MODE=remote VITE_API_BASE_URL=http://127.0.0.1:8787 vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "api": "node ./server/amas-api.mjs",
    "smoke:remote": "node ./scripts/smoke-remote.mjs",
    "smoke:remote:recovery": "node ./scripts/smoke-remote-recovery.mjs",
    "smoke:remote:expiry": "node ./scripts/smoke-remote-session-expiry.mjs",
    "dev:recovered": "./scripts/serve-recovered.sh",
    "ios:recovered": "./scripts/start-ios-recovered.sh",
    "start": "./scripts/serve-recovered.sh",
    "sync:simulator": "./scripts/sync-from-simulator.sh"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  }
}
